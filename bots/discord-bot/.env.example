DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
WEBHOOK_URL=http://localhost:3000/api/webhooks/discord
WEBHOOK_SECRET=your_webhook_secret

# Optional: explicit web API base for campaign commands
# If omitted, derived from WEBHOOK_URL
CAMPAIGN_API_BASE_URL=http://localhost:3000

# Optional: batching controls
BATCH_FLUSH_INTERVAL_MS=15000
BATCH_MAX_KEYS=100
BATCH_RETENTION_MS=1800000
BATCH_WALRUS_ARCHIVE=false

# Required for Seal + Walrus commands (!encrypt / !decrypt)
SUI_NETWORK=testnet
SUI_PRIVATE_KEY=suiprivkey...
PACKAGE_ID=0x...
ORG_REGISTRY_ID=0x...
PROFILE_REGISTRY_ID=0x...
